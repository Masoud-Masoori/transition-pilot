# Set ONE of these (Anthropic preferred; Groq is the fallback):
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
PORT=8089

# When integrating with the Prompt Opinion platform, the platform passes these as
# headers per request (X-FHIR-Server-URL, X-FHIR-Access-Token, X-Patient-Id), so
# the .env values are only used for local development against a mock FHIR server.
FHIR_BASE_URL=http://localhost:9000/fhir
FHIR_BEARER=local-dev-token
